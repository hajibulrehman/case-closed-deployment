# PostgreSQL connection string (Render provides this automatically)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Strong random secret for JWT signing — generate with: openssl rand -base64 48
JWT_SECRET="replace_with_strong_random_secret"

# Port (Render injects this automatically — do not set manually on Render)
PORT=5000

# Comma-separated list of allowed frontend origins
# e.g. CORS_ORIGIN="https://your-frontend.onrender.com"
CORS_ORIGIN="http://localhost:5173"
